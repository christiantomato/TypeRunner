<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="typerunner.frontend.controllers.AccountCreationController">
   <center>
      <StackPane BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0">
               <children>
                  <TextField fx:id="usernameField" focusTraversable="false" maxWidth="300.0" minHeight="50.0" minWidth="300.0" promptText="enter new username..." />
                  <TextField fx:id="passwordField" focusTraversable="false" maxWidth="300.0" minHeight="50.0" minWidth="300.0" promptText="enter new password..." />
                  <TextField fx:id="administratorField" focusTraversable="false" maxWidth="300.0" minHeight="50.0" minWidth="300.0" promptText="enter administrator username..." />
                  <Button minHeight="40.0" minWidth="300.0" mnemonicParsing="false" onAction="#createAccount" text="Create">
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Button>
                  <Text fx:id="creationMessage" strokeType="OUTSIDE" strokeWidth="0.0" />
               </children>
               <padding>
                  <Insets left="20.0" right="20.0" />
               </padding>
            </VBox>
            <MenuButton fx:id="accountType" maxWidth="120.0" minWidth="120.0" mnemonicParsing="false" text="Account Type" translateX="230.0" translateY="-120.0">
              <items>
                <MenuItem mnemonicParsing="false" onAction="#selectAccountType" text="Player" />
                <MenuItem mnemonicParsing="false" onAction="#selectAccountType" text="Administrator" />
              </items>
            </MenuButton>
            <Text stroke="WHITE" strokeType="OUTSIDE" strokeWidth="2.0" text="* Field Required for Player Accounts" translateX="-260.0" translateY="20.0" wrappingWidth="100.0" />
         </children>
      </StackPane>
   </center>
   <top>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Region maxHeight="50.0" maxWidth="65.0" minHeight="50.0" minWidth="50.0" prefHeight="50.0" prefWidth="65.0" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Text stroke="WHITE" strokeType="OUTSIDE" strokeWidth="3.0" styleClass="titles" text="New Account" textAlignment="CENTER">
               <font>
                  <Font size="70.0" />
               </font>
            </Text>
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button alignment="CENTER" minHeight="50.0" minWidth="50.0" mnemonicParsing="false" onAction="#returnToMenu" styleClass="back-button" text="←" textAlignment="CENTER">
               <HBox.margin>
                  <Insets right="15.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
   </top>
</BorderPane>
