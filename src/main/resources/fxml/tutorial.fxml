<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="typerunner.frontend.controllers.TutorialController">
   <top>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Region maxHeight="50.0" maxWidth="65.0" minHeight="50.0" minWidth="50.0" prefHeight="50.0" prefWidth="65.0" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Text stroke="WHITE" strokeType="OUTSIDE" strokeWidth="3.0" styleClass="titles" text="Tutorial" textAlignment="CENTER">
               <font>
                  <Font size="70.0" />
               </font>
            </Text>
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button alignment="CENTER" minHeight="50.0" minWidth="50.0" mnemonicParsing="false" onAction="#returnToMenu" styleClass="back-button" text="←" textAlignment="CENTER">
               <HBox.margin>
                  <Insets right="15.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
   </top>
   <center>
      <StackPane styleClass="text-background" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" spacing="20.0">
               <children>
                  <HBox alignment="CENTER" spacing="20.0">
                     <children>
                        <ImageView fx:id="leftImage" fitHeight="276.0" fitWidth="376.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/tutorial-picture-one.png" />
                           </image>
                        </ImageView>
                        <ImageView fx:id="rightImage" fitHeight="276.0" fitWidth="372.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/tutorial-picture-two.png" />
                           </image>
                        </ImageView>
                     </children>
                  </HBox>
                  <Text fx:id="description" lineSpacing="10.0" stroke="WHITE" strokeType="OUTSIDE" strokeWidth="2.0" styleClass="root" text="The first step in being able to play TypeRunner, is to create an account! To do so, first you must select on &quot;Admin Controls&quot; in the main menu, following this you must enter the games parental passkey; &quot;1234&quot;." textAlignment="CENTER" wrappingWidth="500.0" />
               </children>
            </VBox>
         </children>
         <BorderPane.margin>
            <Insets left="20.0" right="20.0" />
         </BorderPane.margin>
      </StackPane>
   </center>
   <bottom>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="leftButton" alignment="CENTER" minHeight="30.0" minWidth="20.0" mnemonicParsing="false" onAction="#previousPage" styleClass="back-button" text="←" textAlignment="CENTER" />
            <Text fx:id="pageCount" stroke="WHITE" strokeType="OUTSIDE" strokeWidth="2.0" styleClass="root" text="1/10" />
            <Button fx:id="rightButton" alignment="CENTER" minHeight="30.0" minWidth="20.0" mnemonicParsing="false" onAction="#nextPage" styleClass="back-button" text="→" textAlignment="CENTER" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
