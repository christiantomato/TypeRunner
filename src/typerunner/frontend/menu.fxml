<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="typerunner.frontend.MenuController">
   <top>
      <Text strokeType="OUTSIDE" strokeWidth="0.0" text="TypeRunner" textAlignment="CENTER" BorderPane.alignment="CENTER">
         <font>
            <Font size="70.0" />
         </font>
         <BorderPane.margin>
            <Insets bottom="20.0" top="20.0" />
         </BorderPane.margin>
      </Text>
   </top>
   <center>
      <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button minHeight="40.0" minWidth="300.0" mnemonicParsing="false" onAction="#loginPage" text="Login" textAlignment="CENTER" VBox.vgrow="ALWAYS">
               <font>
                  <Font size="20.0" />
               </font></Button>
            <Button minHeight="40.0" minWidth="300.0" mnemonicParsing="false" onAction="#adminControls" text="Admin Controls" VBox.vgrow="ALWAYS">
               <font>
                  <Font size="20.0" />
               </font></Button>
            <Button minHeight="40.0" minWidth="300.0" mnemonicParsing="false" onAction="#viewLeaderboard" text="Leaderboard" VBox.vgrow="ALWAYS">
               <font>
                  <Font size="20.0" />
               </font></Button>
            <Button minHeight="40.0" minWidth="300.0" mnemonicParsing="false" onAction="#tutorial" text="Tutorial" VBox.vgrow="ALWAYS">
               <font>
                  <Font size="20.0" />
               </font></Button>
            <Button minHeight="40.0" minWidth="300.0" mnemonicParsing="false" onAction="#exit" text="Exit" VBox.vgrow="ALWAYS">
               <font>
                  <Font size="20.0" />
               </font></Button>
         </children>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <VBox alignment="BOTTOM_LEFT" prefHeight="200.0" prefWidth="100.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Developers:">
                     <font>
                        <Font size="15.0" />
                     </font>
                  </Text>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Sahej Singh" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Tanya Sahota" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Christian Tamayo" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Noh Woldetinsae" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Olorunfemi Kayode Martins" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" />
               </padding>
            </VBox>
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <VBox alignment="BOTTOM_RIGHT" prefHeight="200.0" prefWidth="100.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Team #1" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Winter 2026" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Created for CS2212 at Western University" />
               </children>
               <padding>
                  <Insets bottom="10.0" right="10.0" />
               </padding>
            </VBox>
         </children>
      </HBox>
   </bottom>
</BorderPane>
