<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="typerunner.frontend.controllers.AdminPasskeyController">
   <top>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Region maxHeight="50.0" maxWidth="50.0" minHeight="50.0" minWidth="50.0" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Passkey">
               <font>
                  <Font size="70.0" />
               </font>
            </Text>
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button maxHeight="50.0" maxWidth="50.0" minHeight="50.0" minWidth="50.0" mnemonicParsing="false" onAction="#mainMenu" text="←" />
         </children>
         <padding>
            <Insets bottom="20.0" left="50.0" right="50.0" top="20.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <StackPane>
         <children>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0">
               <children>
                  <StackPane>
                     <children>
                        <PasswordField fx:id="passkeyField" maxHeight="50.0" maxWidth="300.0" minHeight="50.0" minWidth="300.0" promptText="enter admin passkey..." />
                        <TextField focusTraversable="false" maxWidth="300.0" minHeight="50.0" minWidth="300.0" promptText="enter admin passkey..." visible="false" />
                     </children>
                  </StackPane>
                  <Button minHeight="40.0" minWidth="300.0" mnemonicParsing="false" onAction="#validatePasskey" text="Validate">
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Button>
               </children>
               <padding>
                  <Insets left="20.0" right="20.0" />
               </padding>
            </VBox>
            <CheckBox mnemonicParsing="false" onAction="#togglePasskey" text="Show Passkey" translateX="220.0" translateY="-30.0" />
         </children>
      </StackPane>
   </center>
</BorderPane>
